---
const base = import.meta.env.BASE_URL;
---
<section id="about" class="pt-32 pb-20 md:pt-48 md:pb-32 overflow-hidden bg-[#FBFBF9]">
	<div class="container mx-auto px-6 relative">
		<div class="flex flex-col md:flex-row items-center gap-12 relative">
			<div class="w-full md:w-3/5">
				<span class="inline-block py-1 px-3 rounded-full bg-rose-50 text-stone-600 font-semibold text-sm mb-6 tracking-wide uppercase border border-stone-100">Neuroscience @ William & Mary</span>
				<h1 class="text-5xl md:text-7xl font-extrabold leading-tight mb-8 text-[#1C1917]">
					Neuroscience Researcher & <span class="text-transparent bg-clip-text bg-gradient-to-r from-stone-600 via-stone-800 to-[#1C1917]">Strategic Analyst</span>
				</h1>
				<p class="text-xl text-[#1C1917] mb-10 leading-relaxed max-w-2xl">
					I'm <span class="font-bold text-[#1C1917]">Josephine Binkley</span>, a researcher dedicated to bridging complex biological science with <span class="italic">collaborative leadership</span> and impactful strategy. Through my work in high-stakes lab environments and student leadership, I specialize in combining rigorous analytical skills with effective, team-oriented problem solving.
				</p>
				<div class="flex flex-col sm:flex-row space-y-4 sm:space-y-0 sm:space-x-4">
					<a href="#experience" class="px-8 py-4 bg-[#1C1917] text-white rounded-xl font-bold hover:bg-stone-800 transition-all text-center shadow-lg shadow-stone-200">View Experience</a>
					<a href=`${base}/Optimized Resume.pdf` class="px-8 py-4 bg-rose-50 border border-stone-800 text-stone-800 rounded-xl font-bold hover:bg-rose-100 transition-all text-center flex items-center justify-center shadow-sm" download>
						<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a2 2 0 002 2h12a2 2 0 002-2v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
						</svg>
						Download Resume
					</a>
				</div>
			</div>
			<div class="w-full md:w-2/5 flex justify-center">
				<div class="relative group">
					<div class="absolute -inset-1 bg-gradient-to-r from-stone-200 to-stone-300 rounded-2xl blur opacity-25 group-hover:opacity-50 transition duration-1000 group-hover:duration-200"></div>
					<img 
						src=`${base}/headshot.png` 
						alt="Josephine Binkley" 
						class="relative w-80 h-80 md:w-96 md:h-96 object-cover rounded-2xl shadow-2xl border border-stone-200"
					/>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
</style>