<section id="experience" class="py-24 bg-[#FBFBF9]">
	<div class="container mx-auto px-6">
		<div class="flex flex-col md:flex-row md:items-end justify-between mb-16">
			<div>
				<h2 class="text-4xl font-bold text-[#1C1917] mb-4">Professional Experience</h2>
				<p class="text-stone-600 max-w-xl text-lg">A track record of operational excellence in academic research and organizational leadership.</p>
			</div>
			<div class="mt-6 md:mt-0">
				<a href="#" class="text-[#1C1917] font-bold border-b-2 border-[#1C1917] pb-1 uppercase tracking-wider text-sm hover:text-stone-600 hover:border-stone-600 transition-colors">Download Full CV</a>
			</div>
		</div>

		<div class="space-y-12">
			{experiences.map((exp) => (
				<div class="group relative grid grid-cols-1 md:grid-cols-4 gap-8">
					<div class="md:col-span-1">
						<p class="text-stone-600 font-medium">{exp.period}</p>
						<h4 class="text-stone-500 font-bold mt-1 uppercase tracking-tight text-sm">{exp.company}</h4>
					</div>
					<div class="md:col-span-3 pb-12 border-b border-stone-200 group-last:border-0">
						<h3 class="text-2xl font-bold text-[#1C1917] mb-4 group-hover:text-stone-600 transition-colors">{exp.title}</h3>
						<ul class="space-y-3 mb-6">
							{exp.description.map((item) => (
								<li class="text-[#1C1917] flex items-start">
									<span class="text-stone-400 mr-3 mt-1.5">•</span>
									<span>{item}</span>
								</li>
							))}
						</ul>
						<div class="flex flex-wrap gap-2">
							{exp.tags.map((tag) => (
								<span class="px-3 py-1 bg-rose-50/70 text-stone-700 rounded-md text-xs font-semibold uppercase tracking-wider border border-stone-100">{tag}</span>
							))}
						</div>
					</div>
				</div>
			))}
		</div>
	</div>
</section>