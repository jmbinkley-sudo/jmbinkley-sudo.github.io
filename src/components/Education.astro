<section id="education" class="py-24 bg-[#FBFBF9]">
	<div class="container mx-auto px-6">
		<div class="max-w-4xl mx-auto">
			<h2 class="text-4xl font-bold text-[#1C1917] mb-12">Education</h2>
			
			<div class="relative pl-8 border-l-2 border-stone-200">
				<div class="absolute -left-[9px] top-0 w-4 h-4 bg-rose-700 rounded-full border-4 border-[#FBFBF9]"></div>
				<div class="flex flex-col md:flex-row md:items-center justify-between mb-4">
					<h3 class="text-2xl font-bold text-[#1C1917]">B.S. in Neuroscience</h3>
					<span class="text-stone-600 font-bold">Expected May 2026</span>
				</div>
				<p class="text-xl text-[#1C1917] font-semibold mb-4">William & Mary, Williamsburg, VA</p>
				<div class="flex flex-wrap gap-4 mb-6">
					<div class="bg-stone-50 px-4 py-2 rounded-lg border border-stone-200 shadow-sm">
						<span class="text-stone-600 text-sm block">Major GPA</span>
						<span class="text-[#1C1917] font-bold text-lg">3.71</span>
					</div>
					<div class="bg-stone-50 px-4 py-2 rounded-lg border border-stone-200 shadow-sm">
						<span class="text-stone-600 text-sm block">Cumulative GPA</span>
						<span class="text-[#1C1917] font-bold text-lg">3.48</span>
					</div>
				</div>
				<p class="text-stone-600 leading-relaxed italic">
					Focusing on the intersection of neurobiological processes and behavioral outcomes, with specialized coursework in research methodology and data analysis.
				</p>
			</div>
		</div>
	</div>
</section>