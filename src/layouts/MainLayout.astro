---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { title, description = "Josephine Binkley's Professional Portfolio" } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en" class="scroll-smooth scroll-pt-24">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href=`${base}/favicon.svg` />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&family=Montserrat:wght@700;800&display=swap" rel="stylesheet">
	</head>
	<body id="top" class="bg-[#FBFBF9] text-[#1C1917] font-sans selection:bg-stone-200">
		<header class="fixed top-0 left-0 w-full z-50 bg-[#FBFBF9]/90 backdrop-blur-md border-b border-stone-200">
			<nav class="container mx-auto px-6 py-6 flex justify-between items-center">
				<a href="#top" class="font-montserrat font-bold text-xl text-[#1C1917] uppercase tracking-widest hover:text-stone-600 transition-colors cursor-pointer">JB.</a>
				<div class="hidden md:flex space-x-10 font-semibold text-sm uppercase tracking-wider">
					<a href="#about" class="text-stone-600 hover:text-[#1C1917] transition-colors">About</a>
					<a href="#experience" class="text-stone-600 hover:text-[#1C1917] transition-colors">Experience</a>
					<a href="#leadership" class="text-stone-600 hover:text-[#1C1917] transition-colors">Impact</a>
					<a href="#projects" class="text-stone-600 hover:text-[#1C1917] transition-colors">Research</a>
					<a href="#skills" class="text-stone-600 hover:text-[#1C1917] transition-colors">Skills</a>
				</div>
				<a href="#contact" class="bg-[#1C1917] text-white px-6 py-2 rounded-lg font-bold hover:bg-stone-800 transition-all shadow-sm text-sm uppercase tracking-wider">Contact</a>
			</nav>
		</header>

		<main>
			<slot />
		</main>

		<footer class="bg-[#FBFBF9] text-[#1C1917] py-20 border-t border-stone-200">
			<div class="container mx-auto px-6 text-center">
				<p class="font-montserrat font-bold text-[#1C1917] text-2xl mb-2 tracking-tight uppercase">Josephine Binkley</p>
				<p class="mb-8 text-stone-600 font-medium tracking-wide uppercase text-xs">Neuroscience Researcher & Strategic Analyst</p>
				<div class="flex justify-center space-x-8 mb-10 text-sm">
					<a href="mailto:josiebinkley@outlook.com" class="text-stone-500 hover:text-[#1C1917] transition-colors font-medium">Email</a>
					<a href="https://linkedin.com/in/josephinebinkley" target="_blank" class="text-stone-500 hover:text-[#1C1917] transition-colors font-medium underline underline-offset-4 decoration-stone-200">LinkedIn</a>
					<a href="https://github.com/josiebinkley" target="_blank" class="text-stone-500 hover:text-[#1C1917] transition-colors font-medium">GitHub</a>
				</div>
				<p class="text-[10px] text-stone-400 uppercase tracking-[0.2em]">© {new Date().getFullYear()} Josephine Binkley • Built with Astro</p>
			</div>
		</footer>
	</body>
</html>

<style is:global>
	:root {
		--font-sans: 'Inter', system-ui, -apple-system, sans-serif;
		--font-display: 'Montserrat', sans-serif;
	}
	
	h1, h2, h3, h4 {
		font-family: var(--font-display);
	}

	/* Resetting any global dark mode styles that might be lingering */
	html {
		background-color: #FBFBF9 !important;
		color: #1C1917 !important;
	}
</style>